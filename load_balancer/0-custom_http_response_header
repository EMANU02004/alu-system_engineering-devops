#!/usr/bin/env bash
# Configures Nginx with a custom HTTP response header

apt-get update
apt-get install -y nginx

# shellcheck disable=SC2154
add_header_config="add_header X-Served-By \$hostname;"

sed -i "/http {/a \    $add_header_config" /etc/nginx/nginx.conf

# Restart nginx and apply the changes
service nginx restart
